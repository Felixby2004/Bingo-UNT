# Backend Environment Variables - COPY THIS TO .env AND FILL IN YOUR VALUES
# DO NOT COMMIT THIS FILE WITH REAL VALUES - KEEP REAL .env IN .gitignore

# ===== SERVER =====
PORT=3001
NODE_ENV=production

# ===== DATABASE =====
# Render provides this automatically, or use local PostgreSQL
DATABASE_URL=postgresql://user:password@host:5432/bingo_db?ssl=require

# ===== SECURITY =====
JWT_SECRET=your_secret_key_here_change_this

# ===== FRONTEND URL =====
# URL where your frontend is hosted (for CORS)
FRONTEND_URL=https://your-frontend.onrender.com

# ===== CLOUDINARY (Image/Media Storage) =====
CLOUDINARY_CLOUD_NAME=your_cloudinary_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ===== EMAIL CONFIGURATION (for Login 2FA Codes via SendGrid HTTP) =====
# Get your API Key at https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=your_sendgrid_api_key
# The email address you verified in SendGrid (Sender Identity)
SENDGRID_FROM_EMAIL=your_verified_sender@email.com
ADMIN_EMAIL=your_verified_sender@email.com
EMAIL_VERIFICATION_CODE_EXPIRY=600000

# ===== GOOGLE SHEETS & DRIVE (for Winner Verification) =====
# Create a Service Account at https://console.cloud.google.com
# Download private key and fill these values:
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
# Use the FULL PRIVATE KEY with escaped newlines (\n as literal text, not actual line breaks)
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_SHEET_ID=your_google_sheet_id
GOOGLE_DRIVE_FOLDER_ID=your_google_drive_folder_id

# ===== TIMEZONE =====
TZ=America/Lima

